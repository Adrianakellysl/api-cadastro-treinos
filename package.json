{
  "name": "desafio04-apidecadastro",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "mocha \"test/**/*.test.js\" --timeout 30000 --reporter mochawesome",
    "test:api": "mocha \"test/api/**/*.test.js\" --timeout 30000",
    "coverage": "nyc --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 mocha \"test/**/*.test.js\" --timeout 30000"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "nyc": {
    "all": true,
    "include": [
      "src/**/*.js"
    ],
    "exclude": [
      "src/server.js",
      "src/config/env.js",
      "src/config/database.js",
      "src/config/swagger.js"
    ],
    "reporter": [
      "text",
      "html"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mochawesome": "^7.1.4",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "supertest": "^7.2.2"
  }
}
